"""Top-level Snakefile for Processing-MuAgent.

Rule DAG: p1_context -> s0_ingest (load + validate + assemble plan + QC explore in
          one job) -> plan_review -> s1a_ambient -> s1_rna_qc -> s2_atac_qc ->
          s3_doublets -> post_qc_review -> s4_rna_norm -> s5_atac_spectral ->
          s6_neighbors -> s7_clustering -> s8_umap -> manifest

Each stage has a _propose / _execute pair (see rules/*.smk). The two human-gate
stages (plan_review, post_qc_review) block their downstream execute rules on
checkpoints/<stage>.approved, written by `Processing-MuAgent approve <stage>`;
all other stages (incl. s7_clustering at fixed resolutions) run automatically.

Direct-write layout:
    INTERNAL     = <run_dir>/internal               — artifacts, proposals, checkpoints,
                                                      parameters.yaml, state.yaml, log.jsonl
    DELIVERABLES = <run_dir>/deliverables           — user-facing, split by phase:
      PLAN       = deliverables/plan                — config + approval-support materials
                                                      (run.yaml, biological_context.md,
                                                       context_summary.md, plan_review_<run>.md)
      FIGURES    = deliverables/figures             — all pipeline figures (PNG + PDF)
      QC_REVIEW  = deliverables/qc_review           — QC review reports (md/html)
      RESULTS    = deliverables/results             — final results (data, notebook,
                                                      manifest; no figures)
Rule outputs land directly at their canonical location; no mirroring.
"""
from pathlib import Path

RUN_DIR = Path(config["run_dir"])
INTERNAL = RUN_DIR / "internal"
DELIVERABLES = RUN_DIR / "deliverables"
PLAN = DELIVERABLES / "plan"
FIGURES = DELIVERABLES / "figures"
QC_REVIEW = DELIVERABLES / "qc_review"
RESULTS = DELIVERABLES / "results"

STAGES = [
    "p1_context", "plan_review",
    "s0_ingest", "s1a_ambient", "s1_rna_qc", "s2_atac_qc", "s3_doublets",
    "post_qc_review",
    "s4_rna_norm", "s5_atac_spectral", "s6_neighbors", "s7_clustering", "s8_umap",
    "s_handoff",
]


include: "resources.smk"

include: "rules/p1_context.smk"
include: "rules/plan_review.smk"
include: "rules/s0_ingest.smk"
include: "rules/s1a_ambient.smk"
include: "rules/s1_rna_qc.smk"
include: "rules/s2_atac_qc.smk"
include: "rules/s3_doublets.smk"
include: "rules/post_qc_review.smk"
include: "rules/s4_rna_norm.smk"
include: "rules/s5_atac_spectral.smk"
include: "rules/s6_neighbors.smk"
include: "rules/s7_clustering.smk"
include: "rules/s8_umap.smk"
include: "rules/manifest.smk"
include: "rules/s_handoff.smk"


# Rules that always run on the orchestrator host (login node or runner head-job),
# never submitted as cluster jobs. These are:
#   - all *_propose rules (cheap I/O + sentinel-writing)
#   - light planning execute rules (P1/plan_review; interactive, cheap I/O)
#   - manifest (assembly of summaries + handoff JSON)
#
# s0_ingest_execute is NOT local — it is the merged planning compute job (load +
# validate + assemble plan + QC exploration), pulled in as a dependency when submit
# infers `plan_review_propose` as the planning-phase target.
localrules:
    p1_context_propose, p1_context_execute,
    plan_review_propose,
    s0_ingest_propose,
    s1a_ambient_propose,
    s1_rna_qc_propose,
    s2_atac_qc_propose,
    s3_doublets_propose,
    post_qc_review_propose,
    s4_rna_norm_propose,
    s5_atac_spectral_propose,
    s6_neighbors_propose,
    s7_clustering_propose,
    s8_umap_propose,
    manifest,
    s_handoff,


rule all:
    input:
        str(RESULTS / "run_manifest.json"),
        str(RESULTS / "post_qc_manifest.json"),
